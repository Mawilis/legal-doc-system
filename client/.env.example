# API Configuration (required)
VITE_API_URL=http://localhost:5001

# Development Token (for local development)
VITE_DEV_TOKEN=dev-wilsy-super-admin-token-2026

# Tenant Configuration (required)
VITE_TENANT_ID=WILSY_GLOBAL_001

# App Configuration
VITE_APP_NAME=WILSY OS
VITE_APP_VERSION=7.0.0-OMEGA

# Feature Flags
VITE_ENABLE_QUANTUM_UI=true
VITE_ENABLE_FORENSIC_LOGS=true
