{
  "dashboard": {
    "id": null,
    "uid": "wilsy-audit-telemetry-v1",
    "title": "🏛️ WILSY OS - Sovereign Audit & Telemetry Dashboard",
    "timezone": "browser",
    "refresh": "5s",
    "theme": "dark",
    "schemaVersion": 36,
    "version": 1,
    "panels": [
      {
        "type": "stat",
        "title": "Cryptographic Seal Finality (%)",
        "id": 1,
        "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
        "targets": [
          { "expr": "(wilsy_gauge_clients_sealed_total{tenantId=\"GLOBAL_ROOT\"} / wilsy_gauge_clients_total{tenantId=\"GLOBAL_ROOT\"}) * 100", "legendFormat": "Sealed Integrity" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 2,
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "#d4af37", "value": 99 },
                { "color": "green", "value": 100 }
              ]
            }
          }
        },
        "options": { "colorMode": "background", "justifyMode": "center" }
      },
      {
        "type": "stat",
        "title": "Institutional Authority Sign-offs",
        "id": 2,
        "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 },
        "targets": [
          { "expr": "wilsy_gauge_clients_authority_verified_total{tenantId=\"GLOBAL_ROOT\"}", "legendFormat": "Verified by Board" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": { "fixedColor": "#d4af37", "mode": "fixed" }
          }
        },
        "options": { "colorMode": "background", "justifyMode": "center" }
      },
      {
        "type": "timeseries",
        "title": "Compliance Status Enforcement (Real-time)",
        "id": 3,
        "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },
        "targets": [
          { "expr": "wilsy_client_compliance_state{tenantId=\"GLOBAL_ROOT\"}", "legendFormat": "{{company}}" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": { "drawStyle": "bars" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "orange", "value": 1 },
                { "color": "blue", "value": 2 },
                { "color": "green", "value": 3 }
              ]
            }
          }
        }
      },
      {
        "type": "timeseries",
        "title": "Sovereign Telemetry: Client Creation Strikes",
        "id": 4,
        "gridPos": { "x": 0, "y": 6, "w": 24, "h": 8 },
        "targets": [
          { "expr": "rate(wilsy_counter_client_creation_total{tenantId=\"GLOBAL_ROOT\"}[5m])", "legendFormat": "Creation Velocity" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": { "fixedColor": "green", "mode": "fixed" },
            "custom": { "fillOpacity": 20, "lineInterpolation": "smooth" }
          }
        }
      },
      {
        "type": "text",
        "title": "Boardroom Narrative Overlay",
        "id": 5,
        "gridPos": { "x": 0, "y": 14, "w": 24, "h": 4 },
        "options": {
          "mode": "markdown",
          "content": "### Forensic Finality Report\nThis cockpit visualizes the **Singularity Shard v1.1.0** enforcement. Every client registered in Wilsy OS is mathematically anchored via **SHA3-512 cryptographic seals**. The Boardroom can now verify institutional sign-offs and compliance velocity in a single view, ensuring absolute transparency and indomitable auditability."
        }
      }
    ]
  }
}
