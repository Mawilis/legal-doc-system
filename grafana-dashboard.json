{
  "dashboard": {
    "id": null,
    "uid": "wilsy-sovereign-master",
    "title": "🏛️ WILSY OS - Sovereign Investor Dashboard",
    "timezone": "browser",
    "refresh": "5s",
    "theme": "dark",
    "schemaVersion": 36,
    "version": 1,
    "panels": [
      {
        "type": "stat",
        "title": "Cold Storage Replay Attempts",
        "id": 1,
        "gridPos": { "x": 0, "y": 0, "w": 4, "h": 6 },
        "targets": [
          {
            "expr": "wilsy_counter_telemetry_replay_attempts{tenantId=\"GLOBAL_ROOT\"}",
            "legendFormat": "Attempts"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "short", "color": {"mode": "palette-classic"} } }
      },
      {
        "type": "gauge",
        "title": "Replay Latency SLA (p95)",
        "id": 2,
        "gridPos": { "x": 4, "y": 0, "w": 4, "h": 6 },
        "targets": [
          {
            "expr": "wilsy_latency_telemetry_replay_latency{tenantId=\"GLOBAL_ROOT\", quantile=\"0.95\"}",
            "legendFormat": "p95 Latency"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "min": 0, "max": 1000,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "orange", "value": 300 },
                { "color": "red", "value": 500 }
              ]
            }
          }
        }
      },
      {
        "type": "timeseries",
        "title": "Singularity Nucleus Load",
        "id": 3,
        "gridPos": { "x": 8, "y": 0, "w": 12, "h": 6 },
        "targets": [
          { "expr": "wilsy_system_load", "legendFormat": "CPU Load Avg" }
        ],
        "fieldConfig": { "defaults": { "color": {"mode": "palette-classic"} } }
      },
      {
        "type": "stat",
        "title": "Hardware Logic Cores",
        "id": 4,
        "gridPos": { "x": 20, "y": 0, "w": 4, "h": 6 },
        "targets": [
          { "expr": "wilsy_system_cpu_cores", "legendFormat": "Cores" }
        ],
        "fieldConfig": { "defaults": { "unit": "none" } }
      },
      {
        "type": "timeseries",
        "title": "Telemetry Latency Histograms",
        "id": 5,
        "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
        "targets": [
          { "expr": "wilsy_latency_telemetry_replay_latency{tenantId=\"GLOBAL_ROOT\", quantile=\"0.5\"}", "legendFormat": "p50 (Median)" },
          { "expr": "wilsy_latency_telemetry_replay_latency{tenantId=\"GLOBAL_ROOT\", quantile=\"0.95\"}", "legendFormat": "p95" },
          { "expr": "wilsy_latency_telemetry_replay_latency{tenantId=\"GLOBAL_ROOT\", quantile=\"0.99\"}", "legendFormat": "p99 (Spikes)" }
        ],
        "fieldConfig": { "defaults": { "unit": "ms" } }
      },
      {
        "type": "barchart",
        "title": "Institutional Revenue Allocations (Live DB)",
        "id": 6,
        "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
        "targets": [
          { "expr": "wilsy_revenue_streams{tenantId=\"GLOBAL_ROOT\"}", "legendFormat": "{{stream}}" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "color": { "mode": "palette-classic" }
          }
        },
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient",
          "legend": { "showLegend": true, "placement": "bottom" },
          "tooltip": { "mode": "single" }
        }
      },
      {
        "type": "barchart",
        "title": "Compliance Overlays (Live Ratios)",
        "id": 7,
        "gridPos": { "x": 0, "y": 14, "w": 8, "h": 10 },
        "targets": [
          { "expr": "wilsy_compliance_ratio{tenantId=\"GLOBAL_ROOT\"}", "legendFormat": "{{overlay}}" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0, "max": 100,
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "orange", "value": 75 },
                { "color": "green", "value": 90 }
              ]
            }
          }
        },
        "options": {
          "orientation": "vertical",
          "displayMode": "gradient"
        }
      },
      {
        "type": "table",
        "title": "Immutable Forensic Audit Ledger",
        "id": 8,
        "gridPos": { "x": 8, "y": 14, "w": 16, "h": 10 },
        "targets": [
          {
            "expr": "wilsy_forensic_entry_info{tenantId=\"GLOBAL_ROOT\"}",
            "format": "table",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": { "align": "auto", "cellOptions": { "type": "auto" } }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Validation Status" },
              "properties": [
                { "id": "custom.cellOptions", "value": { "type": "color-background" } },
                {
                  "id": "mappings",
                  "value": [
                    {
                      "type": "value",
                      "options": {
                        "VALID": { "color": "green", "index": 0 },
                        "INVALID": { "color": "red", "index": 1 }
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        "options": {
          "showHeader": true,
          "sortBy": [{ "displayName": "Entry ID", "desc": true }]
        },
        "transformations": [
          { "id": "labelsToFields", "options": {} },
          {
            "id": "organize",
            "options": {
              "excludeByName": { "Time": true, "Value": true, "tenantId": true, "__name__": true },
              "renameByName": {
                "entryId": "Entry ID",
                "traceId": "Trace ID",
                "action": "Action",
                "performer": "Performer",
                "sealHash": "Seal Hash",
                "signature": "Signature",
                "narrative": "Narrative",
                "validation": "Validation Status"
              }
            }
          }
        ]
      }
    ]
  }
}
