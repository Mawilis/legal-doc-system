{
  "dashboard": {
    "title": "Wilsy OS - Enterprise Monitoring",
    "version": 42,
    "timezone": "browser",
    "panels": [
      {
        "title": "System Health Overview",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "wilsy_system_health",
            "legendFormat": "Health Status"
          }
        ],
        "thresholds": [
          { "color": "green", "value": 3 },
          { "color": "yellow", "value": 2 },
          { "color": "red", "value": 1 }
        ]
      },
      {
        "title": "Active Tenants by Tier",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 8, "x": 4, "y": 0 },
        "targets": [
          {
            "expr": "sum by (tier) (wilsy_active_tenants)",
            "legendFormat": "{{tier}}"
          }
        ]
      },
      {
        "title": "Monthly Recurring Revenue",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "sum(wilsy_mrr)",
            "legendFormat": "MRR"
          }
        ],
        "thresholds": [
          { "color": "green", "value": 500000 },
          { "color": "yellow", "value": 750000 },
          { "color": "red", "value": 1000000 }
        ]
      },
      {
        "title": "API Request Rate",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "rate(wilsy_api_calls_total[5m])",
            "legendFormat": "API Calls/s"
          }
        ]
      },
      {
        "title": "Error Rate",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "rate(wilsy_errors_total[5m])",
            "legendFormat": "Errors/s"
          }
        ]
      },
      {
        "title": "CPU Usage",
        "type": "graph",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "wilsy_cpu_usage_percent",
            "legendFormat": "CPU {{core}}"
          }
        ]
      },
      {
        "title": "Memory Usage",
        "type": "graph",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
        "targets": [
          {
            "expr": "wilsy_memory_bytes{type='heapUsed'}",
            "legendFormat": "Heap Used"
          },
          {
            "expr": "wilsy_memory_bytes{type='rss'}",
            "legendFormat": "RSS"
          }
        ]
      },
      {
        "title": "Disk Usage",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 4, "x": 16, "y": 12 },
        "targets": [
          {
            "expr": "wilsy_disk_bytes{type='used'} / wilsy_disk_bytes{type='total'} * 100",
            "legendFormat": "Disk Usage %"
          }
        ],
        "thresholds": [
          { "color": "green", "value": 70 },
          { "color": "yellow", "value": 85 },
          { "color": "red", "value": 95 }
        ]
      },
      {
        "title": "GPU Utilization",
        "type": "graph",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "wilsy_gpu_utilization_percent",
            "legendFormat": "GPU {{gpu_id}}"
          }
        ]
      },
      {
        "title": "GPU Temperature",
        "type": "graph",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
        "targets": [
          {
            "expr": "wilsy_gpu_temperature_celsius",
            "legendFormat": "GPU {{gpu_id}}"
          }
        ],
        "thresholds": [
          { "color": "green", "value": 70 },
          { "color": "yellow", "value": 80 },
          { "color": "red", "value": 90 }
        ]
      },
      {
        "title": "Queue Sizes",
        "type": "graph",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
        "targets": [
          {
            "expr": "wilsy_queue_size",
            "legendFormat": "{{queue_name}} ({{priority}})"
          }
        ]
      },
      {
        "title": "Cache Hit Rate",
        "type": "graph",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
        "targets": [
          {
            "expr": "rate(wilsy_cache_hits_total[5m]) / (rate(wilsy_cache_hits_total[5m]) + rate(wilsy_cache_misses_total[5m])) * 100",
            "legendFormat": "Cache Hit Rate %"
          }
        ]
      },
      {
        "title": "Database Query Duration",
        "type": "heatmap",
        "gridPos": { "h": 8, "w": 16, "x": 0, "y": 32 },
        "targets": [
          {
            "expr": "rate(wilsy_db_query_duration_seconds_bucket[1m])",
            "legendFormat": "{{operation}} - {{collection}}"
          }
        ]
      },
      {
        "title": "Search Queries by Type",
        "type": "barchart",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 40 },
        "targets": [
          {
            "expr": "sum by (type) (rate(wilsy_search_queries_total[1h]))",
            "legendFormat": "{{type}}"
          }
        ]
      },
      {
        "title": "Cross-Jurisdiction Maps",
        "type": "worldmap",
        "gridPos": { "h": 8, "w": 16, "x": 8, "y": 40 },
        "targets": [
          {
            "expr": "sum by (source_jurisdiction, target_jurisdiction) (rate(wilsy_jurisdiction_maps_total[1h]))",
            "legendFormat": "{{source_jurisdiction}} → {{target_jurisdiction}}"
          }
        ]
      },
      {
        "title": "Component Health",
        "type": "table",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 48 },
        "targets": [
          {
            "expr": "wilsy_component_health",
            "format": "table",
            "instant": true
          }
        ],
        "columns": [
          { "text": "Component", "value": "component" },
          { "text": "Status", "value": "Value" }
        ],
        "thresholds": [
          { "color": "green", "value": 1 },
          { "color": "yellow", "value": 0.5 },
          { "color": "red", "value": 0 }
        ]
      },
      {
        "title": "Event Loop Lag",
        "type": "graph",
        "gridPos": { "h": 4, "w": 8, "x": 8, "y": 48 },
        "targets": [
          {
            "expr": "wilsy_event_loop_lag_seconds",
            "legendFormat": "Event Loop Lag"
          }
        ],
        "thresholds": [
          { "color": "green", "value": 0.05 },
          { "color": "yellow", "value": 0.1 },
          { "color": "red", "value": 0.5 }
        ]
      }
    ],
    "annotations": {
      "list": [
        {
          "name": "Deployments",
          "type": "dashboard",
          "enable": true,
          "iconColor": "blue"
        },
        {
          "name": "Alerts",
          "type": "dashboard",
          "enable": true,
          "iconColor": "red"
        }
      ]
    },
    "refresh": "30s",
    "time": { "from": "now-6h", "to": "now" },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"],
      "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
    },
    "tags": ["wilsy-os", "production", "monitoring"],
    "description": "Wilsy OS Enterprise Monitoring Dashboard"
  }
}
