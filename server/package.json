{
  "name": "wilsy-os-server",
  "version": "2.0.0",
  "type": "module",
  "description": "WILSY OS - Revolutionary Legal Technology Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "NODE_ENV=test NODE_OPTIONS=\"--experimental-vm-modules\" mocha --config .mocharc.cjs --file tests/setup.cjs tests/advanced/*.test.cjs --timeout 300000 --exit",
    "test:finance": "NODE_OPTIONS='--experimental-vm-modules' npx mocha --require @babel/register __tests__/finance/**/*.test.js --exit",
    "test:billing": "NODE_OPTIONS='--experimental-vm-modules' npx mocha --require @babel/register __tests__/billing/**/*.test.js --exit",
    "test:all": "NODE_ENV=test NODE_OPTIONS=\"--experimental-vm-modules\" mocha --config .mocharc.cjs tests/ --recursive --timeout 30000 --exit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:document": "NODE_ENV=test NODE_OPTIONS=\"--experimental-vm-modules\" mocha --config .mocharc.cjs tests/unit/DocumentTemplate.test.js tests/unit/DocumentGenerationEngine.test.js tests/integration/documentGeneration.integration.test.js --timeout 30000 --exit",
    "test:unit": "NODE_ENV=test NODE_OPTIONS=\"--experimental-vm-modules\" mocha --config .mocharc.cjs tests/unit/ --timeout 10000 --exit",
    "test:integration": "NODE_ENV=test NODE_OPTIONS=\"--experimental-vm-modules\" mocha --config .mocharc.cjs tests/integration/ --timeout 30000 --exit",
    "test:advanced": "NODE_ENV=test NODE_OPTIONS=\"--experimental-vm-modules\" mocha --config .mocharc.cjs --file tests/setup.cjs tests/advanced/AdvancedDocumentGeneration.test.cjs --timeout 300000 --exit",
    "investor-report": "node scripts/investor-report.js",
    "monitor": "../monitor-production.sh",
    "test:helpers": "NODE_ENV=test mocha --experimental-specifier-resolution=node tests/helpers/testDatabaseHelper.test.js --exit"
  },
