{
  "name": "wilsy-os-server",
  "version": "2.0.0",
  "type": "module",
  "description": "WILSY OS - Revolutionary Legal Technology Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' npx mocha --require @babel/register __tests__/**/*.test.js --exit",
    "test:finance": "NODE_OPTIONS='--experimental-vm-modules' npx mocha --require @babel/register __tests__/finance/**/*.test.js --exit",
    "test:billing": "NODE_OPTIONS='--experimental-vm-modules' npx mocha --require @babel/register __tests__/billing/**/*.test.js --exit",
    "test:all": "NODE_ENV=test NODE_OPTIONS=\"--experimental-vm-modules\" mocha --config .mocharc.cjs tests/ --recursive --timeout 30000 --exit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:document": "NODE_ENV=test NODE_OPTIONS=\"--experimental-vm-modules\" mocha --config .mocharc.cjs tests/unit/DocumentTemplate.test.js tests/unit/DocumentGenerationEngine.test.js tests/integration/documentGeneration.integration.test.js --timeout 30000 --exit",
    "test:unit": "NODE_ENV=test NODE_OPTIONS=\"--experimental-vm-modules\" mocha --config .mocharc.cjs tests/unit/ --timeout 10000 --exit",
    "test:integration": "NODE_ENV=test NODE_OPTIONS=\"--experimental-vm-modules\" mocha --config .mocharc.cjs tests/integration/ --timeout 30000 --exit"
  },
  "dependencies": {
    "@tensorflow/tfjs": "4.11.0",
    "@xenova/transformers": "^2.5.4",
    "agenda": "^5.0.0",
    "bullmq": "5.70.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "docxtemplater": "3.68.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "gpu.js": "2.15.0",
    "handlebars": "4.7.8",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.4.4",
    "mongoose": "^8.2.4",
    "node-cron": "^3.0.3",
    "pdf-lib": "1.17.1",
    "pizzip": "3.2.0",
    "stopword": "^2.0.8",
    "validator": "^13.15.20",
    "winston": "^3.11.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "7.29.0",
    "@babel/register": "7.28.6",
    "@tensorflow/tfjs-node": "4.11.0",
    "@types/jest": "30.0.0",
    "brain.js": "2.0.0-beta.1",
    "chai": "5.3.3",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "29.7.0",
    "mocha": "11.3.0",
    "mongodb-memory-server": "9.5.0",
    "natural": "6.3.0",
    "nodemon": "^3.0.3",
    "quantum-circuit": "0.9.247",
    "redis-mock": "0.56.3",
    "sinon": "17.0.1",
    "supertest": "6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Wilson Khanyezi",
  "license": "UNLICENSED",
  "private": true
}
