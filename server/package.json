{
  "name": "wilsy-os",
  "version": "3.0.0",
  "type": "module",
  "description": "Wilsy OS - Sovereign Legal Technology Platform",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint . --quiet --fix",
    "lint:check": "eslint . --quiet",
    "lint:strict": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules\" mocha 'tests/**/*.test.{js,cjs,mjs}' '__tests__/**/*.test.{js,cjs,mjs}' --recursive --timeout 10000",
    "test:coverage": "c8 npm test",
    "prepare": "husky install",
    "dev:debug": "nodemon --inspect server.js",
    "dev:test": "NODE_ENV=test nodemon server.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.540.0",
    "@sentry/node": "7.108.0",
    "bullmq": "5.7.9",
    "chalk": "4.1.2",
    "compression": "1.7.4",
    "cookie-parser": "1.4.6",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "express-async-handler": "1.2.0",
    "express-mongo-sanitize": "2.2.0",
    "express-rate-limit": "6.7.0",
    "express-request-id": "1.4.1",
    "helmet": "7.1.0",
    "hpp": "0.2.3",
    "ioredis": "5.3.2",
    "mongoose": "8.2.4",
    "morgan": "1.10.0",
    "prom-client": "14.2.0",
    "swagger-ui-express": "4.6.3",
    "uuid": "9.0.0",
    "winston": "3.9.0",
    "xss-clean": "0.1.1",
    "yamljs": "0.3.0"
  },
  "devDependencies": {
    "c8": "10.1.2",
    "chai": "5.1.1",
    "eslint": "9.10.0",
    "husky": "9.1.6",
    "lint-staged": "15.2.10",
    "mocha": "10.7.3",
    "nodemon": "3.1.0",
    "prettier": "3.3.3",
    "pretty-quick": "4.0.0",
    "proxyquire": "2.1.3",
    "sinon": "18.0.0",
    "supertest": "7.0.0"
  },
  "lint-staged": {
    "*.{js,cjs,mjs}": [
      "prettier --write",
      "eslint --fix --quiet"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
