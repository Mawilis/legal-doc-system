{
  "name": "wilsy-os-server",
  "version": "2.0.0",
  "type": "module",
  "description": "WILSY OS - Revolutionary Legal Technology Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' mocha --require @babel/register 'tests/**/*.test.js'",
    "test:file": "NODE_OPTIONS='--experimental-vm-modules' mocha --require @babel/register",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' mocha --require @babel/register --watch 'tests/**/*.test.js'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@xenova/transformers": "2.17.2",
    "agenda": "^5.0.0",
    "bullmq": "5.70.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "8.2.1",
    "helmet": "^7.1.0",
    "ioredis": "5.10.0",
    "joi": "17.13.3",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.4.4",
    "mongoose": "^8.2.4",
    "natural": "^6.9.0",
    "node-cron": "^3.0.3",
    "socket.io": "4.8.3",
    "stopword": "^2.0.8",
    "validator": "13.15.20",
    "winston": "^3.11.0",
    "ws": "8.19.0",
    "xss": "1.0.15"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/register": "^7.23.7",
    "chai": "4.3.10",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "lint-staged": "16.2.7",
    "mocha": "11.3.0",
    "mongodb-memory-server": "^9.1.6",
    "nodemon": "^3.0.3",
    "prettier": "3.8.1",
    "sinon": "^17.0.1",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Wilson Khanyezi",
  "license": "UNLICENSED",
  "private": true
}

  "scripts": {
    "test:finance": "NODE_OPTIONS='--experimental-vm-modules' mocha --require @babel/register __tests__/finance/**/*.test.js --exit",
    "test:billing": "NODE_OPTIONS='--experimental-vm-modules' mocha --require @babel/register __tests__/billing/**/*.test.js --exit",
    "test:all": "NODE_OPTIONS='--experimental-vm-modules' mocha --require @babel/register __tests__/**/*.test.js --exit"
  }
