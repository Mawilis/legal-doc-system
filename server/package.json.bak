{
  "name": "wilsy-os-server",
  "version": "2026.2.0",
  "description": "WILSY OS - Sovereign Legal Operating System | © 2026 Wilsy (Pty) Ltd",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "NODE_ENV=development nodemon server.js",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules\" mocha \"tests/**/*.test.{js,cjs,mjs}\" \"__tests__/**/*.test.{js,cjs,mjs}\" --recursive --timeout 10000",
    "lint": "eslint . --quiet --fix",
    "security:audit": "npm audit --production",
    "docker:build": "docker build -t wilsy-os:latest .",
    "migrate": "node scripts/migrate.js",
    "test:watch": "mocha test/**/*.test.js --watch",
    "test:investor": "NODE_ENV=test npx mocha tests/models/LegalPrecedent.mocha.js --timeout 30000",
    "investor:report": "NODE_ENV=test npx mocha tests/models/LegalPrecedent.mocha.js --grep \"INVESTOR SUMMARY\" --timeout 30000",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:staged": "pretty-quick --staged",
    "format:js": "prettier --write \"**/*.{js,cjs,mjs}\"",
    "format:json": "prettier --write \"**/*.json\"",
    "format:fix": "npm run format && npm run lint",
    "prepare": "husky install",
    "lint:check": "eslint . --quiet",
    "lint:strict": "eslint . --max-warnings=0"
  },
  "keywords": [
    "legal-tech",
    "sovereign-os",
    "popia-compliant",
    "fiza",
    "document-automation"
  ],
  "author": "Wilson Khanyezi <wilsy.wk@gmail.com>",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@aws-sdk/client-s3": "^3.985.0",
    "@elastic/elasticsearch": "^9.3.2",
    "@mapbox/node-pre-gyp": "^2.0.3",
    "@mongodb-js/zstd": "^7.0.0",
    "@sentry/node": "^7.85.0",
    "@tensorflow-models/universal-sentence-encoder": "^1.3.3",
    "@tensorflow/tfjs-node": "^0.1.21",
    "@xenova/transformers": "^2.17.2",
    "@zilliz/milvus2-sdk-node": "^2.6.10",
    "argon2": "^0.31.2",
    "async-mutex": "^0.5.0",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "bull": "^4.11.5",
    "bull-board": "^1.2.0",
    "bullmq": "^5.70.1",
    "compression": "^1.8.1",
    "connect-mongo": "^3.2.0",
    "connect-redis": "^7.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "crypto-js": "^4.2.0",
    "csrf": "^3.1.0",
    "dotenv": "^16.3.1",
    "ejs": "^3.0.2",
    "es-to-primitive": "^1.2.1",
    "exceljs": "^4.1.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-openapi-validator": "^5.6.2",
    "express-prom-bundle": "^6.6.0",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.2.0",
    "i18next": "^23.7.6",
    "i18next-fs-backend": "^2.2.0",
    "ioredis": "^5.9.3",
    "is-callable": "^1.2.7",
    "isolation-forest": "^0.0.9",
    "joi": "^17.11.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "libsodium-wrappers": "^0.7.13",
    "luxon": "^3.7.2",
    "mammoth": "^1.11.0",
    "ml-random-forest": "^2.1.0",
    "moment": "^2.29.4",
    "moment-timezone": "^0.6.0",
    "mongodb": "^6.3.0",
    "mongoose": "^7.8.2",
    "mongoose-delete": "^1.0.2",
    "mongoose-encryption": "^2.1.2",
    "mongoose-paginate-v2": "^1.9.1",
    "morgan": "^1.10.0",
    "msgpack-lite": "^0.1.26",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "natural": "^8.1.0",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.1",
    "opossum": "^9.0.0",
    "otplib": "^12.0.1",
    "p-limit": "^7.3.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "prom-client": "^15.1.3",
    "puppeteer": "^24.37.2",
    "redis": "^4.6.11",
    "request-ip": "^3.3.0",
    "sanitize-html": "^2.11.0",
    "sequelize": "^6.37.7",
    "stopword": "^3.1.5",
    "stripe": "^14.15.0",
    "tar": "^7.4.0",
    "twilio": "^4.19.2",
    "validator": "^13.11.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^4.7.1",
    "xss": "^1.0.15",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^0.1.0",
    "@eslint/js": "^9.10.0",
    "@faker-js/faker": "^8.3.1",
    "@types/express": "^4.17.21",
    "@types/ioredis-mock": "^8.2.6",
    "@types/jest": "^29.5.14",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20.10.5",
    "@types/uuid": "^10.0.0",
    "chai": "^6.2.2",
    "eslint": "^10.0.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^21.27.2",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-mocha": "^10.4.3",
    "eslint-plugin-react": "^7.22.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-security": "^2.1.0",
    "globals": "^15.3.0",
    "husky": "^8.0.3",
    "ioredis-mock": "^8.13.1",
    "jest": "^25.0.0",
    "lint-staged": "^15.2.0",
    "mocha": "^11.7.5",
    "mongodb-memory-server": "^9.5.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "pretty-quick": "^3.1.0",
    "proxyquire": "^2.1.3",
    "rate-limiter-flexible": "^2.4.2",
    "sinon": "^21.0.1",
    "supertest": "^6.3.4",
    "uuid": "^9.0.1"
  },
  "mocha": {
    "timeout": 30000,
    "exit": true,
    "ignore": [
      "node_modules/**"
    ],
    "recursive": true,
    "reporter": "spec"
  },
  "type": "module",
  "lint-staged": {
    "*.{js,cjs,mjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
