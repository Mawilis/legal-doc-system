// INTEGRATION_HINT: Router mounted at /api in server.js, all sub-routes inherit middleware

/**
 * ASSUMPTIONS & DEFAULTS:
 * • Tenant ID format: /^[a-zA-Z0-9_-]{8,64}$/ (extracted from header or JWT)
 * • Rate limits: 1000 requests/hour for authenticated, 100/hour for unauthenticated
 * • Retention policy: 'api_access_logs_3_years' for all API requests
 * • Data residency: 'ZA' (South Africa) for POPIA compliance
 * • Response format: JSON with consistent envelope structure
 * • Error format: RFC 7807 Problem Details for HTTP APIs
 * • Audit logging: Every request logged with tenant context
 * • Request ID: Generated for traceability across services
 */

// ============================================================================
// CONSTANTS & CONFIGURATION
// ============================================================================

const API_VERSION = 'v1';
const API_PREFIX = '/api';
const SERVICE_NAME = 'WILSY-OS-API';
const BUILD_VERSION = process.env.BUILD_VERSION || '2.0.0-investor-grade';
const DEPLOYMENT_ENV = process.env.NODE_ENV || 'development';

const RATE_LIMITS = {
  authenticated: parseInt(process.env.RATE_LIMIT_AUTH || '1000', 10), // 1000/hour
  unauthenticated: parseInt(process.env.RATE_LIMIT_PUBLIC || '100', 10) // 100/hour
};

const RESPONSE_ENVELOPE = {
  alwaysInclude: ['success', 'data', 'timestamp', 'requestId'],
  errorInclude: ['code', 'message', 'details']
};

const RETENTION_POLICY = {
  api_logs: {
    name: 'api_access_logs_3_years',
    legalReference: 'ECT Act §15(2) - Electronic Evidence, POPIA §19 - Access Records',
    retentionPeriod: 1095, // days (3 years)
    mandatoryFields: ['tenantId', 'method', 'path', 'statusCode', 'requestId']
  }
};

// ============================================================================
// HELPER FUNCTIONS (PRIVATE)
// ============================================================================

/**
 * Generates a unique request ID for traceability
 * @returns {string} - Request ID (format: req_<timestamp>_<random>)
 */
function generateRequestId() {
  const timestamp = Date.now();
  const random = randomBytes(8).toString('hex');
  return `req_${timestamp}_${random}`;
}

/**
 * Formats successful response with consistent envelope
 * @param {Object} data - Response data
 * @param {string} requestId - Request ID for tracing
 * @returns {Object} - Formatted response
 */
function formatSuccess(data, requestId) {
  return {
    success: true,
    data,
    timestamp: new Date().toISOString(),
    requestId,
    service: SERVICE_NAME,
    version: BUILD_VERSION
  };
}

/**
 * Formats error response according to RFC 7807
 * @param {Error|string} error - Error object or message
 * @param {number} statusCode - HTTP status code
 * @param {string} requestId - Request ID for tracing
 * @returns {Object} - RFC 7807 compliant error response
 */
function formatError(error, statusCode = 500, requestId) {
  const errorMessage = error instanceof Error ? error.message : error;
  
  return {
    type: 'https://api.wilsyos.com/errors/' + statusCode,
    title: getHttpStatusTitle(statusCode),
    status: statusCode,
    detail: errorMessage,
    instance: requestId,
    timestamp: new Date().toISOString(),
    service: SERVICE_NAME
  };
}

/**
 * Gets HTTP status title from code
 * @param {number} statusCode - HTTP status code
 * @returns {string} - Status title
 */
function getHttpStatusTitle(statusCode) {
  const titles = {
    400: 'Bad Request',
    401: 'Unauthorized',
    403: 'Forbidden',
    404: 'Not Found',
    405: 'Method Not Allowed',
    408: 'Request Timeout',
    409: 'Conflict',
    422: 'Unprocessable Entity',
    429: 'Too Many Requests',
    500: 'Internal Server Error',
    502: 'Bad Gateway',
    503: 'Service Unavailable'
  };
  return titles[statusCode] || 'Unknown Error';
}

/**
 * Logs API request to audit trail
 * @param {Object} req - Express request
 * @param {Object} res - Express response
 * @param {number} durationMs - Request duration in ms
 */
async function logApiRequest(req, res, durationMs) {
  try {
    const tenantId = req.tenantContext?.tenantId || 'public';
    const userId = req.user?.id || req.tenantContext?.userId || 'anonymous';
    
    // Redact sensitive headers
    const headers = { ...req.headers };
    delete headers.authorization;
    delete headers.cookie;
    delete headers['x-api-key'];
    
    const auditEntry = {
      action: 'API_REQUEST',
      resourceType: 'api',
      tenantId,
      userId,
      requestId: req.requestId,
      method: req.method,
      path: req.originalUrl || req.url,
      query: req.query,
      statusCode: res.statusCode,
      durationMs,
      userAgent: req.get('user-agent'),
      ip: req.ip || req.connection.remoteAddress,
      headers: headers,
      timestamp: new Date().toISOString(),
      retentionPolicy: RETENTION_POLICY.api_logs.name,
      retentionPeriod: RETENTION_POLICY.api_logs.retentionPeriod,
      legalReference: RETENTION_POLICY.api_logs.legalReference,
      dataResidency: process.env.DEFAULT_DATA_RESIDENCY || 'ZA'
    };
    
    await auditLogger.log('api-access', auditEntry);
  } catch (error) {
    logger.error('Failed to log API request', { 
      error: error.message,
      requestId: req.requestId 
    });
  }
}

// ============================================================================
// MIDDLEWARE
// ============================================================================

/**
 * Request ID middleware - adds unique ID to each request
 */
function requestIdMiddleware(req, res, next) {
  req.requestId = generateRequestId();
  res.setHeader('X-Request-ID', req.requestId);
  next();
}

/**
 * Response time middleware - tracks request duration
 */
function responseTimeMiddleware(req, res, next) {
  const start = process.hrtime();
  
  res.on('finish', () => {
    const diff = process.hrtime(start);
    const durationMs = (diff[0] * 1e3 + diff[1] * 1e-6).toFixed(2);
    req.durationMs = durationMs;
    
    // Log after response is sent
    logApiRequest(req, res, durationMs).catch(err => 
      logger.error('Async audit log failed', { error: err.message })
    );
    
    logger.debug('Request completed', {
      method: req.method,
      path: req.originalUrl,
      statusCode: res.statusCode,
      durationMs,
      requestId: req.requestId
    });
  });
  
  next();
}

/**
 * Security headers middleware
 */
function securityHeadersMiddleware(req, res, next) {
  // HSTS
  res.setHeader('Strict-Transport-Security', 'max-age=31536000; includeSubDomains; preload');
  
  // Prevent MIME type sniffing
  res.setHeader('X-Content-Type-Options', 'nosniff');
  
  // XSS protection
  res.setHeader('X-XSS-Protection', '1; mode=block');
  
  // Prevent clickjacking
  res.setHeader('X-Frame-Options', 'DENY');
  
  // Content Security Policy
  res.setHeader('Content-Security-Policy', "default-src 'none'; frame-ancestors 'none'; base-uri 'none'");
  
  // Referrer policy
  res.setHeader('Referrer-Policy', 'strict-origin-when-cross-origin');
  
  // Remove X-Powered-By
  res.removeHeader('X-Powered-By');
  
  // CORS headers
  res.setHeader('Access-Control-Allow-Origin', process.env.CORS_ORIGIN || 'https://app.wilsyos.com');
  res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, PATCH, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-Request-ID, X-Tenant-ID, X-API-Key');
  res.setHeader('Access-Control-Expose-Headers', 'X-Request-ID');
  res.setHeader('Access-Control-Allow-Credentials', 'true');
  res.setHeader('Access-Control-Max-Age', '86400'); // 24 hours
  
  // Handle preflight
  if (req.method === 'OPTIONS') {
    return res.status(204).end();
  }
  
  next();
}

/**
 * CORS middleware wrapper
 */
function corsMiddleware(req, res, next) {
  // Set CORS headers based on origin
  const origin = req.headers.origin;
  const allowedOrigins = (process.env.ALLOWED_ORIGINS || 'https://app.wilsyos.com,https://admin.wilsyos.com').split(',');
  
  if (origin && allowedOrigins.includes(origin)) {
    res.setHeader('Access-Control-Allow-Origin', origin);
  }
  
  next();
}

// ============================================================================
// ROUTER INITIALIZATION
// ============================================================================

const router = express.Router();

// Apply global middleware in order
router.use(requestIdMiddleware);
router.use(responseTimeMiddleware);
router.use(securityHeadersMiddleware);
router.use(corsMiddleware);
router.use(extractTenant); // Extract tenant from header/JWT
router.use(rateLimiter(RATE_LIMITS)); // Apply rate limiting
router.use(express.json({ limit: '10mb' })); // Parse JSON bodies
router.use(express.urlencoded({ extended: true, limit: '10mb' }));

