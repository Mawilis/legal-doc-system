// ============================================================================
// MOUNT INVESTOR ROUTES
// ============================================================================

/**
 * Investor routes mounted at /api/investor
 * All routes require authentication and tenant context
 * Rate limiting: 1000 requests/hour (authenticated)
 */
router.use('/investor', 
  authenticate({ required: true }), // Require authentication for all investor routes
  validateRequest({ schema: 'investor' }), // Validate request schema
  auditMiddleware({ action: 'INVESTOR_API_ACCESS' }), // Audit all investor API access
  investorRoutes // Mount the investor routes
);

// ============================================================================
// 404 HANDLER
// ============================================================================

/**
 * 404 handler for undefined routes
 */
router.use('*', (req, res) => {
  logger.warn('Route not found', {
    method: req.method,
    path: req.originalUrl,
    requestId: req.requestId
  });
  
  res.status(404).json(formatError(
    `Cannot ${req.method} ${req.originalUrl}`,
    404,
    req.requestId
  ));
});

// ============================================================================
// ERROR HANDLING MIDDLEWARE
// ============================================================================

/**
 * Global error handler
 */
router.use((err, req, res, next) => {
  // Log error
  logger.error('API error', {
    error: err.message,
    stack: err.stack,
    method: req.method,
    path: req.originalUrl,
    requestId: req.requestId,
    tenantId: req.tenantContext?.tenantId
  });
  
  // Determine status code
  const statusCode = err.statusCode || err.status || 500;
  
  // Format error response
  const errorResponse = formatError(err, statusCode, req.requestId);
  
  // Add validation errors if present
  if (err.validationErrors) {
    errorResponse.validationErrors = err.validationErrors;
  }
  
  // Send response
  res.status(statusCode).json(errorResponse);
});

// ============================================================================
// EXPORTS
// ============================================================================

export default router;

