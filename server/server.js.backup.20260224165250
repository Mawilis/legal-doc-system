async function performStartupChecks() {
  generationalLogger.info('🔍 PERFORMING GENERATIONAL STARTUP CHECKS...');

  const checks = [
    {
      name: 'Database Connection',
      check: () => mongoose.connection.readyState === 1,
      critical: true,
    },
    {
      name: 'Environment Variables',
      check: () => {
        const required = ['NODE_ENV'];
        return required.every((env) => process.env[env] !== undefined);
      },
      critical: true,
    },
    {
      name: 'File System Access',
      check: async () => {
        try {
          await fs.access(path.join(__dirname, '../../logs'));
          return true;
        } catch {
          await fs.mkdir(path.join(__dirname, '../../logs'), { recursive: true });
          return true;
        }
      },
      critical: false,
    },
    {
      name: 'Required Ports',
      check: () => SYSTEM_CONFIG.PORT > 0 && SYSTEM_CONFIG.PORT < 65536,
      critical: true,
    },
    {
      name: 'JWT Secret',
      check: () => SYSTEM_CONFIG.JWT_SECRET && SYSTEM_CONFIG.JWT_SECRET.length >= 32,
      critical: true,
    },
  ];

  let allCriticalPassed = true;

  for (const check of checks) {
    try {
      const result = await (typeof check.check === 'function' ? check.check() : check.check);
      if (result) {
        generationalLogger.info(`✅ ${check.name}: PASSED`);
      } else {
        if (check.critical) {
          allCriticalPassed = false;
          generationalLogger.error(`❌ ${check.name}: FAILED (CRITICAL)`);
        } else {
          generationalLogger.warn(`⚠️  ${check.name}: FAILED (Non-critical)`);
        }
      }
    } catch (error) {
      if (check.critical) {
        allCriticalPassed = false;
        generationalLogger.error(`💥 ${check.name}: ERROR - ${error.message} (CRITICAL)`);
      } else {
        generationalLogger.warn(`⚠️  ${check.name}: ERROR - ${error.message} (Non-critical)`);
      }
    }
  }

  if (!allCriticalPassed) {
    generationalLogger.error('❌ CRITICAL STARTUP CHECKS FAILED - System may be unstable');
  } else {
    generationalLogger.generational('🎉 STARTUP CHECKS COMPLETE - SYSTEM OPERATIONAL');
