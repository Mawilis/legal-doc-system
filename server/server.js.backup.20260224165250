  }

  async loadAllRoutes() {
    generationalLogger.generational('🚀 LOADING 10 GENERATIONS OF ROUTES...');

    // Sort by generation and priority
    this.manifest.sort((a, b) => {
      if (a.generation !== b.generation) return a.generation - b.generation;
      return a.priority - b.priority;
    });

    for (const route of this.manifest) {
      try {
        const result = await this.loadRoute(route);
        if (result) {
          this.loadedCount++;
          generationalLogger.generational(`✅ Generation ${route.generation}: ${route.mount}`);
        } else {
          this.failedCount++;
          generationalLogger.warn(`⚠️  Generation ${route.generation} (planned): ${route.mount}`);
        }
      } catch (error) {
        this.failedCount++;
        generationalLogger.debug(
          `Route not yet implemented: ${route.mount} - Generation ${route.generation} (Future)`
        );
      }
    }

    generationalLogger.generational(
      `📊 ROUTES LOADED: ${this.loadedCount} active, ${this.failedCount} future (10 generations planned)`
    );
    return { loaded: this.loadedCount, failed: this.failedCount };
  }

  async loadRoute(routeConfig) {
    try {
      const resolvedPath = path.resolve(__dirname, routeConfig.path);

      // Check if file exists
      try {
        await fs.access(resolvedPath);
      } catch (error) {
        // File doesn't exist yet - that's okay for future generations
        return false;
      }

      // Clear require cache for hot reload in development
      if (SYSTEM_CONFIG.NODE_ENV === 'development') {
        delete require.cache[require.resolve(resolvedPath)];
      }

      // Dynamic import for ES modules
      let routeModule;
      try {
        routeModule = await import(resolvedPath);
      } catch (importError) {
        // Try require as fallback
        routeModule = require(resolvedPath);
      }

      if (!routeModule) {
        throw new Error(`Module ${routeConfig.path} exported nothing`);
      }

      // Handle different export patterns
      let router = null;

      if (routeModule.router && typeof routeModule.router === 'function') {
        router = routeModule.router;
      } else if (routeModule.default && routeModule.default.router) {
        router = routeModule.default.router;
      } else if (routeModule.default && typeof routeModule.default === 'function') {
        router = routeModule.default;
      } else if (typeof routeModule === 'function') {
        router = routeModule;
      }

      if (!router) {
        // Try to find any express router in the exports
        for (const key of Object.keys(routeModule)) {
          if (
            routeModule[key] &&
            typeof routeModule[key] === 'function' &&
            routeModule[key].stack
          ) {
            router = routeModule[key];
            break;
          }
        }
      }

      if (!router) {
        throw new Error(`No valid router found in ${routeConfig.path}`);
      }

      // Mount the router
      app.use(routeConfig.mount, router);
      this.routes.set(routeConfig.mount, {
        path: routeConfig.path,
        generation: routeConfig.generation,
        priority: routeConfig.priority,
        loadedAt: new Date(),
      });

      return true;
    } catch (error) {
      // Don't log as error for future generations
      if (routeConfig.generation <= 2) {
        generationalLogger.debug(`Route not ready: ${routeConfig.path}`, { error: error.message });
      }
      return false;
    }
  }
}

