class GenerationalErrorHandler {
  static setup(app) {
    // 404 Handler
    app.use((req, res) => {
      generationalLogger.warn('404 - Route not found', {
        path: req.path,
        method: req.method,
        tenant: req.tenant?.id,
        ip: req.ip,
        requestId: req.generationalRequestId,
      });

      res.status(404).json({
        success: false,
        error: {
          code: 'GENERATIONAL_NOT_FOUND',
          message: `The requested resource ${req.path} does not exist in this generation`,
          generation: 10,
          documentation: 'https://docs.wilsyos.legal/10g',
          requestId: req.generationalRequestId,
        },
      });
    });

    // Global error handler
    app.use((err, req, res, next) => {
      const requestId = req.generationalRequestId || uuidv4();

      // Log with generational context
      generationalLogger.error('💥 GENERATIONAL EXCEPTION', {
        requestId,
        tenant: req.tenant?.id,
        path: req.path,
        method: req.method,
        ip: req.ip,
        error: err.message,
        stack: err.stack,
        generation: 10,
        timestamp: new Date().toISOString(),
      });

      // Record metrics
      billionDollarMetrics.apiErrors.inc({
        error_type: err.name || 'UnknownError',
        endpoint: req.path,
        status_code: err.statusCode || 500,
      });

      // Determine status code
      let statusCode = err.statusCode || err.status || 500;
      let errorCode = err.code || 'GENERATIONAL_ERROR';
      let message = err.message || 'An unexpected error occurred';

      // Common error mappings
      if (err.name === 'ValidationError') {
        statusCode = 400;
        errorCode = 'VALIDATION_ERROR';
        message = 'Data validation failed';
      } else if (err.name === 'UnauthorizedError' || err.name === 'JsonWebTokenError') {
        statusCode = 401;
        errorCode = 'UNAUTHORIZED';
        message = 'Authentication required';
      } else if (err.name === 'ForbiddenError') {
        statusCode = 403;
        errorCode = 'FORBIDDEN';
        message = 'Insufficient permissions';
      } else if (err.name === 'NotFoundError') {
        statusCode = 404;
        errorCode = 'NOT_FOUND';
        message = 'Resource not found';
      } else if (err.name === 'ConflictError') {
        statusCode = 409;
        errorCode = 'CONFLICT';
        message = 'Resource conflict detected';
      } else if (err.name === 'RateLimitError') {
        statusCode = 429;
        errorCode = 'RATE_LIMITED';
        message = 'Too many requests';
      } else if (err.code === 11000) {
        statusCode = 409;
        errorCode = 'DUPLICATE_KEY';
        message = 'Duplicate key error';
      }

      // Build error response
      const errorResponse = {
        success: false,
        error: {
          code: errorCode,
          message: message,
          generation: 10,
          requestId,
          timestamp: new Date().toISOString(),
          documentation: `https://errors.wilsyos.legal/${errorCode.toLowerCase()}`,
        },
      };

      // Add validation errors if present
      if (err.errors) {
        errorResponse.error.details = Object.keys(err.errors).reduce((acc, key) => {
          acc[key] = err.errors[key].message;
          return acc;
        }, {});
      }

      // Add stack trace in development
      if (SYSTEM_CONFIG.NODE_ENV === 'development') {
        errorResponse.error.stack = err.stack;
        errorResponse.error.internal = err.toString();
      }

      res.status(statusCode).json(errorResponse);
    });
  }
}

