class GenerationalShutdownHandler {
  constructor() {
    this.isShuttingDown = false;
    this.shutdownTimeout = 30000; // 30 seconds
    this.setupSignalHandlers();
  }

  setupSignalHandlers() {
    const signals = ['SIGTERM', 'SIGINT', 'SIGHUP', 'SIGQUIT'];

    signals.forEach((signal) => {
      process.on(signal, async () => {
        if (this.isShuttingDown) return;

        generationalLogger.generational(`🛑 GENERATIONAL SHUTDOWN: Received ${signal}`);
        generationalLogger.billion('💰 PRESERVING GENERATIONAL WEALTH...');

        await this.initiateShutdown(signal);
      });
    });

    // Unhandled errors
    process.on('unhandledRejection', (reason, promise) => {
      generationalLogger.error('UNHANDLED REJECTION', {
        reason: reason instanceof Error ? reason.message : reason,
        stack: reason instanceof Error ? reason.stack : undefined,
      });

      // Don't exit, just log and continue
      billionDollarMetrics.apiErrors.inc({
        error_type: 'UnhandledRejection',
        endpoint: 'global',
        status_code: 500,
      });
    });

    process.on('uncaughtException', (error) => {
      generationalLogger.error('UNCAUGHT EXCEPTION', {
        error: error.message,
        stack: error.stack,
      });

      billionDollarMetrics.apiErrors.inc({
        error_type: 'UncaughtException',
        endpoint: 'global',
        status_code: 500,
      });

      // Don't exit immediately for generational stability
      // Instead, log and continue
      setTimeout(() => {
        if (!this.isShuttingDown) {
          this.initiateShutdown('UNCAUGHT_EXCEPTION');
        }
      }, 5000);
    });
  }

  async initiateShutdown(reason) {
    this.isShuttingDown = true;

    generationalLogger.generational(`🚦 SHUTDOWN SEQUENCE: ${reason}`);

    const shutdownTimer = setTimeout(() => {
      generationalLogger.error('💀 SHUTDOWN TIMEOUT - Forcing exit');
      process.exit(1);
    }, this.shutdownTimeout);

    // Step 1: Stop accepting new connections
    if (serverInstance) {
      generationalLogger.info('Closing HTTP server...');
      await new Promise((resolve) => {
        serverInstance.close(() => {
          generationalLogger.info('HTTP server closed');
          resolve();
        });
      });
    }

    // Step 2: Close database connections
    try {
      generationalLogger.info('Closing database connections...');
      await generationalDatabase.disconnect();
      generationalLogger.info('Database connections closed');
    } catch (err) {
      generationalLogger.error('Database close error', { error: err.message });
    }

    // Step 3: Close Redis
    try {
      generationalLogger.info('Closing Redis connections...');
      await generationalRedis.quit();
      generationalLogger.info('Redis connections closed');
    } catch (err) {
      generationalLogger.error('Redis close error', { error: err.message });
    }

    // Step 4: Flush audit trail
    try {
      await generationalLogger.flushAuditTrail();
    } catch (err) {
      // Ignore
    }

    // Step 5: Final log
    generationalLogger.generational('🔄 SHUTDOWN COMPLETE - Generational wealth preserved');
    generationalLogger.billion('💰 10 GENERATIONS PROTECTED');

    // Step 6: Exit
    clearTimeout(shutdownTimer);
    setTimeout(() => {
      process.exit(0);
    }, 1000).unref();
  }
}

