/*
 * ===========================================================================
 * SECTION 5: GENERATIONAL DATABASE - 100-YEAR DATA ARCHITECTURE
 * ===========================================================================
 * MongoDB connection with 10-generation data retention
 */

class GenerationalDatabase {
  constructor() {
    this.connection = null;
    this.retryCount = 0;
    this.maxRetries = 10;
    this.reconnecting = false;
    this.metrics = {
      connections: 0,
      disconnections: 0,
      queries: 0,
      errors: 0,
      avgQueryTime: 0,
    };
  }

  async connect(uri = SYSTEM_CONFIG.MONGO_URI) {
    const startTime = performance.now();

    mongoose.set('strictQuery', true);
    mongoose.set('bufferCommands', false);
    mongoose.set('strictPopulate', false);
    mongoose.set('autoIndex', SYSTEM_CONFIG.NODE_ENV === 'development');
    mongoose.set('maxTimeMS', 30000);

    // Add mongoose plugins globally
    this.addGlobalPlugins();

    try {
      generationalLogger.info('🌌 INITIATING GENERATIONAL DATABASE CONNECTION...', {
        uri: uri.replace(/\/\/[^@]+@/, '//*:*@'),
      });

      this.connection = await mongoose.connect(uri, {
        serverSelectionTimeoutMS: SYSTEM_CONFIG.DATABASE.serverSelectionTimeoutMS,
        socketTimeoutMS: SYSTEM_CONFIG.DATABASE.socketTimeoutMS,
        maxPoolSize: SYSTEM_CONFIG.DATABASE.maxPoolSize,
        minPoolSize: SYSTEM_CONFIG.DATABASE.minPoolSize,
        maxIdleTimeMS: 30000,
        autoIndex: false,
        family: 4,
        retryWrites: true,
        retryReads: true,
        w: 'majority',
        journal: true,
        readPreference: 'primary',
        compressors: SYSTEM_CONFIG.DATABASE.compressors,
      });

      const duration = (performance.now() - startTime).toFixed(2);
      this.metrics.connections++;

      generationalLogger.generational(
        `✅ GENERATIONAL DATABASE: Neural link established in ${duration}ms`
      );
      generationalLogger.billion('💰 DATABASE: Billion-query infrastructure online');

      // Setup event listeners
      this.setupEventListeners();

      // Create indexes for 10-generation performance
      await this.createGenerationalIndexes();

      return true;
    } catch (error) {
      this.metrics.errors++;
      this.retryCount++;

      generationalLogger.error(`DATABASE CONNECTION ERROR: ${error.message}`, {
        code: error.code,
        retryCount: this.retryCount,
      });

      if (this.retryCount <= this.maxRetries) {
        const delay = Math.min(1000 * Math.pow(2, this.retryCount), 30000);
        generationalLogger.warn(
          `Reconnection attempt ${this.retryCount}/${this.maxRetries} in ${delay}ms`
        );
        await new Promise((resolve) => setTimeout(resolve, delay));
        return this.connect(uri);
      } else {
        generationalLogger.error('💀 GENERATIONAL DATABASE FAILURE: Maximum retries exceeded');
        throw error;
      }
    }
  }

  addGlobalPlugins() {
    // Add soft delete plugin
    mongoose.plugin((schema) => {
      schema.add({
        deletedAt: Date,
        deletedBy: { type: mongoose.Schema.Types.ObjectId, ref: 'User' },
      });

      schema.methods.softDelete = async function (userId) {
        this.deletedAt = new Date();
        this.deletedBy = userId;
        return this.save();
      };

      schema.query.notDeleted = function () {
        return this.where({ deletedAt: null });
      };
    });

    // Add audit trail plugin
    mongoose.plugin((schema) => {
      schema.add({
        auditTrail: [
          {
            action: String,
            userId: { type: mongoose.Schema.Types.ObjectId, ref: 'User' },
            timestamp: Date,
            ip: String,
            userAgent: String,
            changes: mongoose.Schema.Types.Mixed,
          },
        ],
      });

      schema.methods.addAuditEntry = async function (action, userId, req = {}) {
        this.auditTrail = this.auditTrail || [];
        this.auditTrail.push({
          action,
          userId,
          timestamp: new Date(),
          ip: req.ip || req.connection?.remoteAddress,
          userAgent: req.headers?.['user-agent'],
          changes: this.modifiedPaths().reduce((acc, path) => {
            acc[path] = this.get(path);
            return acc;
          }, {}),
        });
        return this.save();
      };
    });

    // Add tenant isolation plugin
    mongoose.plugin((schema) => {
      schema.add({
        tenantId: { type: String, required: true, index: true },
        dataResidency: { type: String, default: 'ZA', enum: ['ZA', 'NG', 'KE', 'GH', 'EG'] },
      });

      schema.query.byTenant = function (tenantId) {
        return this.where({ tenantId });
      };
    });

    // Add retention policy plugin
    mongoose.plugin((schema) => {
      schema.add({
        retentionPolicy: {
          type: String,
          enum: ['companies_act_7_years', 'popia_standard', 'permanent_covenant'],
          default: 'companies_act_7_years',
        },
        retentionStart: Date,
        retentionEnd: Date,
        archivedAt: Date,
      });

      schema.methods.shouldExpire = function () {
        return this.retentionEnd && this.retentionEnd < new Date();
      };
    });
  }

  setupEventListeners() {
    mongoose.connection.on('error', (err) => {
      this.metrics.errors++;
      generationalLogger.error(`DATABASE ERROR: ${err.message}`, { errorCode: err.code });
    });

    mongoose.connection.on('disconnected', () => {
      this.metrics.disconnections++;
      generationalLogger.warn('DATABASE DISCONNECTED: Billion-dollar recovery initiated');
      this.reconnect();
    });

    mongoose.connection.on('reconnected', () => {
      generationalLogger.info('DATABASE RECONNECTED: Generational wealth preserved');
    });

    mongoose.connection.on('connected', () => {
      generationalLogger.debug('Database connection established');
    });

    // Monitor query performance
    mongoose.set('debug', (collection, method, query, doc, options) => {
      this.metrics.queries++;
      if (SYSTEM_CONFIG.NODE_ENV === 'development') {
        generationalLogger.debug(`MONGO: ${collection}.${method}`, { query, options });
      }
    });
  }

  async reconnect() {
    if (this.reconnecting) return;
    this.reconnecting = true;

    try {
      await mongoose.disconnect();
      await this.connect();
      this.reconnecting = false;
    } catch (err) {
      generationalLogger.error('Reconnection failed', { error: err.message });
      setTimeout(() => this.reconnect(), 5000);
    }
  }

  async createGenerationalIndexes() {
    try {
      const startTime = performance.now();

      // List of models to create indexes for
      const models = ['User', 'Tenant', 'Document', 'Case', 'Precedent', 'AuditTrail', 'Invoice'];

      for (const modelName of models) {
        try {
          const model = mongoose.model(modelName);
          if (model && model.createIndexes) {
            await model.createIndexes();
            generationalLogger.debug(`Indexes created for ${modelName}`);
          }
        } catch (error) {
          // Model might not be registered yet
        }
      }

      const duration = (performance.now() - startTime).toFixed(2);
      generationalLogger.info(`Database indexes verified in ${duration}ms`);
    } catch (error) {
      generationalLogger.error('Index creation failed', { error: error.message });
    }
  }

  getMetrics() {
    return {
      ...this.metrics,
      readyState: mongoose.connection.readyState,
      host: mongoose.connection.host,
      name: mongoose.connection.name,
      collections: Object.keys(mongoose.connection.collections).length,
    };
  }

  async disconnect() {
    generationalLogger.info('Closing database connections...');
    await mongoose.disconnect();
    generationalLogger.info('Database connections closed');
  }
}

const generationalDatabase = new GenerationalDatabase();

/*
 * ===========================================================================
 * SECTION 6: BILLION-DOLLAR REDIS - GENERATIONAL CACHE
 * ===========================================================================
 * Redis cache layer for billion-scale performance
 */

class GenerationalRedis {
  constructor() {
    this.client = null;
    this.status = 'disconnected';
    this.metrics = {
      hits: 0,
      misses: 0,
      errors: 0,
      avgLatency: 0,
    };
  }

  async connect(url = SYSTEM_CONFIG.REDIS_URL) {
    try {
      generationalLogger.info('🔴 INITIATING GENERATIONAL CACHE...');

      this.client = new Redis(url, {
        retryStrategy: (times) => {
          const delay = Math.min(times * 100, 5000);
          generationalLogger.warn(`Redis reconnection attempt ${times}, delay: ${delay}ms`);
          return delay;
        },
        ...SYSTEM_CONFIG.REDIS,
      });

      this.setupEventListeners();

      // Wait for ready state
      await new Promise((resolve, reject) => {
        this.client.once('ready', resolve);
        this.client.once('error', reject);
        setTimeout(() => reject(new Error('Redis connection timeout')), 10000);
      });

      generationalLogger.generational('🔴 GENERATIONAL CACHE: Billion-dollar Redis online');
      generationalLogger.billion('💰 REDIS READY: Financial data cache operational');

      return true;
    } catch (error) {
      this.metrics.errors++;
      generationalLogger.error(`Redis connection failed: ${error.message}`);
      throw error;
    }
  }

  setupEventListeners() {
    this.client.on('connect', () => {
      this.status = 'connected';
    });

    this.client.on('ready', () => {
      this.status = 'ready';
    });

    this.client.on('error', (err) => {
      this.metrics.errors++;
      generationalLogger.error(`Redis error: ${err.message}`, { code: err.code });
    });

    this.client.on('close', () => {
      this.status = 'closed';
      generationalLogger.warn('Redis connection closed');
    });

    this.client.on('reconnecting', () => {
      this.status = 'reconnecting';
    });
  }

  async get(key) {
    const startTime = performance.now();

    try {
      const value = await this.client.get(key);
      const latency = performance.now() - startTime;

      this.metrics.avgLatency = this.metrics.avgLatency * 0.9 + latency * 0.1;

      if (value) {
        this.metrics.hits++;
        return JSON.parse(value);
      } else {
        this.metrics.misses++;
        return null;
      }
    } catch (error) {
      this.metrics.errors++;
      generationalLogger.error(`Redis get failed: ${error.message}`, { key });
      return null;
    }
  }

  async set(key, value, ttl = 3600) {
    const startTime = performance.now();

    try {
      const serialized = JSON.stringify({
        value,
        metadata: {
          created: Date.now(),
          ttl,
          generation: 10,
        },
      });

      await this.client.setex(key, ttl, serialized);

      const latency = performance.now() - startTime;
      this.metrics.avgLatency = this.metrics.avgLatency * 0.9 + latency * 0.1;

      return true;
    } catch (error) {
      this.metrics.errors++;
      generationalLogger.error(`Redis set failed: ${error.message}`, { key });
      return false;
    }
  }

  async setGenerational(key, value, ttl = 3600) {
    return this.set(`generational:${key}`, value, ttl);
  }

  async getGenerational(key) {
    return this.get(`generational:${key}`);
  }

  async del(key) {
    try {
      await this.client.del(key);
      return true;
    } catch (error) {
      generationalLogger.error(`Redis del failed: ${error.message}`, { key });
      return false;
    }
  }

  async flush() {
    try {
      await this.client.flushall();
      generationalLogger.info('Redis cache flushed');
      return true;
    } catch (error) {
      generationalLogger.error('Redis flush failed', { error: error.message });
      return false;
    }
  }

  async quit() {
    generationalLogger.info('Closing Redis connections...');
    await this.client.quit();
    generationalLogger.info('Redis connections closed');
  }

  getMetrics() {
    return {
      ...this.metrics,
      status: this.status,
      hitRate: this.metrics.hits / (this.metrics.hits + this.metrics.misses) || 0,
    };
  }
}

